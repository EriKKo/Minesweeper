# Copy to .env and fill in values for local development.
# The server auto-loads .env when present (process.loadEnvFile).

PORT=1337

# Enables the "Dev sign-in" button (local testing only — never in production).
DEV_AUTH=1

# Base URL for OAuth callbacks; must match PORT locally and be a registered
# Authorized redirect URI in the provider console.
OAUTH_REDIRECT_BASE=http://localhost:1337

# Google OAuth (names match the fly.io secrets). Get these from
# Google Cloud Console -> APIs & Services -> Credentials.
google_auth_client_id=
google_auth_client_secret=

# GitHub OAuth (optional) — github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
